<% layout('./layouts/boilerplate')%>


<link rel="stylesheet" href="/styleSheets/star.css">

<script>
  const maptilerApiKey = '<%-process.env.MAPTILER_API_KEY%>';
  const campground = <%- JSON.stringify(campground) %>
</script>



  <div class="row">
    <div class="col-6 ">
      <div class="card mb-3">
        <img src="<%= campground.image %>" class="card-img-top" alt="No Image Available">
        <div class="card-body">
          <h5 class="card-title">
            <%= campground.title %>
          </h5>
          <p class="card-text">
            <%= campground.description %>.
          </p>
        </div>
        <ul class="list-group list-group-flush">
          <li class="list-group-item text-muted">
            <%= campground.location %>
          </li>
          <li class="list-group-item">&#8377;<%= campground.price %>/night</li>
          <li class="list-group-item">Submitted by: <%= campground.user.username %></li>
        </ul>
        <%if(currentUser && campground.user.equals(currentUser._id)){%>
          <div class="card-body">
            <a class="btn btn-warning" href="/campgrounds/<%= campground._id %>/edit">Edit The Campground</a>
            <form class="d-inline" action="/campgrounds/<%=campground._id%>/delete?_method=DELETE" method="POST">
              <button class="btn btn-danger">Delete The Campground</button>
            </form>
          </div>
          <%}%>
      </div>
    </div>
    <div class="col-6">
      <div id="map" class="mb-3" style="width:100%; height: 300px;"></div>
        <% if(currentUser){%>
        <h2>Leave a Review</h2>
        <form class="needs-validation mb-3" action="/campgrounds/<%=campground._id%>/reviews" method="POST" novalidate>
          <div class="mb-3">            
            <fieldset class="starability-grow">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
            
            <!-- <label class="form-label" for="rating">Rating</label>
            <input class="form-range" type="range" name="review[rating]" id="rating" min="0" max="5" required> -->
          </div>
          <div class="mb-3">
            <label class="form-label" for="description">Review</label>
            <textarea class="form-control" name="review[body]" id="description" cols="30" rows="3" required></textarea>
          </div>
          <button class="btn btn-success">Submit</button>
        </form>
        <%}%>
          <% for(let i of campground.reviews){ %>
            <div class="card mb-3">
              <div class="card-body">
                <h5 class="card-title mb-2">
                  <p class="starability-result" data-rating="<%=i.rating%>">
                  </p>
                </h5>
                <h6 class="card-subtitle mb-2 text-muted">@<%= i.user.username%></h6>
                <p class="card-text">Review: <%=i.body%>
                </p>
                <% if(currentUser && i.user.equals(currentUser._id)){%>
                <form action="/campgrounds/<%=campground._id%>/reviews/<%=i._id%>?_method=DELETE" method="POST">
                  <button class="btn btn-danger">Delete</button>
                </form>
                <% } %>
              </div>
            </div>
            <% } %>
      </div>
  </div>

 
<script src="/javascripts/showMap.js"></script>